<form version="1.1" theme="dark">
  <label>Network Syslog Intelligence Center</label>
  <description>Comprehensive monitoring for Cisco and Brocade network infrastructure | Real-time syslog analysis and alerting</description>

  <!-- GLOBAL FILTERS -->
  <fieldset submitButton="true" autoRun="true">
    <input type="time" token="time_range" searchWhenChanged="true">
      <label>Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="vendor" searchWhenChanged="true">
      <label>Vendor</label>
      <choice value="*">All Vendors</choice>
      <choice value="cisco">Cisco</choice>
      <choice value="brocade">Brocade</choice>
      <default>*</default>
    </input>
    <input type="dropdown" token="severity" searchWhenChanged="true">
      <label>Severity</label>
      <choice value="*">All Severities</choice>
      <choice value="0">Emergency (0)</choice>
      <choice value="1">Alert (1)</choice>
      <choice value="2">Critical (2)</choice>
      <choice value="3">Error (3)</choice>
      <choice value="4">Warning (4)</choice>
      <choice value="5">Notice (5)</choice>
      <choice value="6">Informational (6)</choice>
      <choice value="7">Debug (7)</choice>
      <default>*</default>
    </input>
    <input type="text" token="device_filter" searchWhenChanged="true">
      <label>Device Filter</label>
      <default>*</default>
      <prefix>host=</prefix>
    </input>
    <input type="dropdown" token="facility" searchWhenChanged="true">
      <label>Facility</label>
      <choice value="*">All Facilities</choice>
      <choice value="0">Kernel (0)</choice>
      <choice value="1">User (1)</choice>
      <choice value="4">Auth (4)</choice>
      <choice value="10">Security (10)</choice>
      <choice value="16">Local0 (16)</choice>
      <choice value="17">Local1 (17)</choice>
      <choice value="18">Local2 (18)</choice>
      <choice value="19">Local3 (19)</choice>
      <choice value="20">Local4 (20)</choice>
      <choice value="21">Local5 (21)</choice>
      <choice value="22">Local6 (22)</choice>
      <choice value="23">Local7 (23)</choice>
      <default>*</default>
    </input>
  </fieldset>

  <!-- BASE SEARCH FOR PERFORMANCE -->
  <search id="base_syslog">
    <query>
      index=network_syslog $device_filter$
      | rex field=_raw "^&lt;(?&lt;pri&gt;\d+)&gt;"
      | eval pri=tonumber(pri)
      | eval vendor_detected=case(
          match(host, "(?i)^(SW-|RTR-|cisco|ios)"), "cisco",
          match(host, "(?i)(FCX|ICX|VDX|brocade)"), "brocade",
          match(_raw, "%(LINK|SPANTREE|SYS|SEC_LOGIN|OSPF|EIGRP|BGP|HSRP|CDP|LINEPROTO)-"), "cisco",
          match(_raw, "%(ACL|SECURITY|LACP|LLDP)-"), "brocade",
          1==1, "unknown"
        )
      | where if("$vendor$"="*", 1=1, vendor_detected="$vendor$")
      | rex field=_raw "%(?&lt;facility_code&gt;[A-Z][A-Z0-9_]*)-(?&lt;sev_code&gt;[0-7])-(?&lt;mnemonic&gt;[A-Z0-9_]+)"
      | eval sev_num=coalesce(tonumber(sev_code), if(isnum(pri), pri%8, null()))
      | eval facility_num=if(isnum(pri), floor(pri/8), null())
      | where if("$severity$"="*", 1=1, sev_num=$severity$)
      | where if("$facility$"="*", 1=1, facility_num=$facility$)
    </query>
    <earliest>$time_range.earliest$</earliest>
    <latest>$time_range.latest$</latest>
  </search>

